# Ignore everything by default
*
.*

# Root files
!.gitignore
!README.md
!docker-compose.yml
!railway.json

# Backend
!backend/
!backend/src/
!backend/src/**
!backend/pom.xml
!backend/Dockerfile

# Frontend
!frontend/
!frontend/src/
!frontend/src/**
!frontend/angular.json
!frontend/package.json
!frontend/package-lock.json
!frontend/tsconfig.json
!frontend/tsconfig.app.json
!frontend/tsconfig.spec.json
!frontend/Dockerfile
!frontend/nginx.conf
!frontend/vercel.json
!frontend/.env.example

# Docker
!docker/
!docker/mysql/
!docker/mysql/Dockerfile
!docker/mysql/my.cnf
!docker/init/
!docker/init/**
